#!/bin/sh /etc/rc.common

START=70
STOP=10

USE_PROCD=1

start_service() {
    procd_open_instance
    procd_set_param command /usr/lib/hotspotos/internal/wifi.sh start
    procd_set_param respawn
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance

    # Start DHCP and NAT
    /usr/lib/hotspotos/internal/dhcp.sh start
    /usr/lib/hotspotos/internal/nat.sh start
}

stop_service() {
    /usr/lib/hotspotos/internal/wifi.sh stop
    /usr/lib/hotspotos/internal/dhcp.sh stop
    /usr/lib/hotspotos/internal/nat.sh stop
}

reload_service() {
    /usr/lib/hotspotos/internal/wifi.sh restart
    /usr/lib/hotspotos/internal/dhcp.sh restart
    /usr/lib/hotspotos/internal/nat.sh restart
}

service_triggers() {
    procd_add_reload_trigger "hotspotos" "wireless" "network" "dhcp"
}
