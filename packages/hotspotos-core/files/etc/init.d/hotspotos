#!/bin/sh /etc/rc.common

START=99
STOP=10

USE_PROCD=1

PROG=/usr/sbin/hotspotos
CONF=/etc/config/hotspotos

start_service() {
    procd_open_instance
    procd_set_param command $PROG daemon
    procd_set_param respawn
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance

    # Start all sub-services
    /usr/lib/hotspotos/service.sh start
}

stop_service() {
    /usr/lib/hotspotos/service.sh stop
}

reload_service() {
    /usr/lib/hotspotos/service.sh reload
}

service_triggers() {
    procd_add_reload_trigger "hotspotos"
}
