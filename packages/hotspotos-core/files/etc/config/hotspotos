config system 'system'
	option version '1.0.0'
	option device 'KolakTek Vetch-NB403'
	option platform 'lantiq/xrx200'
	option kernel '5.10.156'
	option openwrt '22.03'
	option web_port '8080'
	option https_port '443'
	option lan_ip '192.168.1.20'
	option status 'active'
	option debug '0'

config external 'external'
	option enabled '1'
	option gateway '192.168.88.1'
	option username ''
	option password ''
	option auto_reconnect '1'
	option save_password '1'
	option status 'disconnected'
	option last_login ''
	option session_time '0'
	option login_url ''

config ttl 'ttl'
	option enabled '1'
	option mode 'increase'
	option value '1'
	option interface 'wan'

config hotspot 'hotspot'
	option enabled '1'
	option ssid 'KolakTek WiFi'
	option domain 'hotspot.local'
	option gateway '192.168.10.1'
	option pool_start '192.168.10.100'
	option pool_end '192.168.10.250'
	option netmask '255.255.255.0'
	option dhcp_lease '12h'
	option security 'wpa2'
	option password ''
	option channel 'auto'
	option band '2g'

config trial 'trial'
	option enabled '1'
	option duration '10'
	option identification 'mac'
	option allow_once '1'
	option db_path '/etc/hotspotos/trial.db'

config portal 'portal'
	option enabled '1'
	option name 'KolakTek Hotspot'
	option logo '/www/hotspotos/logo.png'
	option welcome_msg 'Welcome to KolakTek Hotspot'
	option login_type 'voucher'
	option theme 'default'
	option redirect_url ''
