#!/bin/sh /etc/rc.common

START=85
STOP=10

USE_PROCD=1

PROG=/usr/lib/hotspotos/trial/trial.sh

start_service() {
    procd_open_instance
    procd_set_param command $PROG start
    procd_set_param respawn
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance

    # Start timer loop
    /usr/lib/hotspotos/trial/timer.sh loop &
}

stop_service() {
    $PROG stop
    killall -f "timer.sh" 2>/dev/null
}

service_triggers() {
    procd_add_reload_trigger "hotspotos"
}
